# .env - Copy this to .env and fill in your values
# NEVER commit this file to git

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# Vaux iOS app — shared secret the app sends as Authorization: Bearer <token>
APP_API_TOKEN=replace-with-a-random-secret

# Apple Health webhook protection
HEALTH_WEBHOOK_TOKEN=replace-with-a-random-secret

# Optional app timezone (defaults to Australia/Sydney)
APP_TIMEZONE=Australia/Sydney

# Optional server port
PORT=5000
